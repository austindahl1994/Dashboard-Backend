{
  "compilerOptions": {
    /* === File & Output Structure === */
    "rootDir": "./src",
    "outDir": "./dist",

    /* === Language & Module Settings === */
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,

    /* === Type Support === */
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true,

    /* === Strictness === */
    "strict": true,
    "noImplicitAny": false,

    /* === Source Maps === */
    "sourceMap": true,

    /* === Other === */
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* ✅ Updated path alias (no baseUrl) */
    "paths": {
      "@/*": ["./src/*"]
    },

    "allowJs": true,
    "checkJs": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
